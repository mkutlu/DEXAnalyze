<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon background — diagonal navy → teal gradient
  matching the DEXAnalyze logo palette (#0A2540 → #0E4C75 → #1A8FA8).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:color="#0A2540" android:offset="0.0" />
                <item android:color="#0E4C75" android:offset="0.5" />
                <item android:color="#1A8FA8" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
